#!/bin/bash
# Resources/ lives one level up from MacOS/ — always correct regardless of
# where the .app is placed (Applications, Downloads, anywhere).
RESOURCES="$(cd "$(dirname "$0")/../Resources" && pwd)"
cd "$RESOURCES"

# .app bundles have a minimal PATH — add common uv install locations
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

LOG="$TMPDIR/audiobook-downloader-launch.log"

_dialog() {
    osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\"" 2>/dev/null
}

_error() {
    TAIL=$(tail -20 "$LOG" 2>/dev/null | sed "s/\"/'/g")
    osascript -e "display dialog \"$1\n\nDetails:\n$TAIL\" buttons {\"OK\"} default button \"OK\"" 2>/dev/null
    exit 1
}

# ── Install uv if missing ───────────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
    _dialog "First-time setup: installing uv (Python manager). This takes about 10 seconds."
    curl -LsSf https://astral.sh/uv/install.sh | sh >>"$LOG" 2>&1
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
fi

if ! command -v uv &>/dev/null; then
    _error "Could not install uv.\nPlease install it from https://docs.astral.sh/uv/ then reopen the app."
fi

# ── Sync dependencies (downloads PyQt6 ~200 MB on first run) ───────────────
if ! uv sync >>"$LOG" 2>&1; then
    _error "Dependency installation failed."
fi

# ── Launch GUI ──────────────────────────────────────────────────────────────
uv run gui.py >>"$LOG" 2>&1
EXIT=$?

if [ $EXIT -ne 0 ]; then
    _error "The app exited with an error (code $EXIT)."
fi
